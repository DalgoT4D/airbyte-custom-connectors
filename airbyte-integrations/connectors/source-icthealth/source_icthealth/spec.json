{
    "documentationUrl": "",
    "connectionSpecification": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "ICT Health Spec",
        "type": "object",
        "required": [
            "toDate",
            "fromDate",
            "userName",
            "password"
        ],
        "additionalProperties": true,
        "properties": {
            "userName": {
                "title": "Username",
                "type": "string",
                "description": "Username",
                "order": 0
            },
            "password": {
                "title": "Password",
                "type": "string",
                "description": "Username",
                "airbyte_secret": true,
                "order": 1
            },
            "fromDate": {
                "title": "From Date",
                "type": "string",
                "description": "Starting date",
                "pattern": "^[0-9]{2}-[A-Za-z]{3}-[0-9]{4}$",
                "examples": [
                    "20-Sep-2020"
                ],
                "order": 2
            },
            "toDate": {
                "title": "End Date",
                "type": "string",
                "description": "Ending date",
                "pattern": "^[0-9]{2}-[A-Za-z]{3}-[0-9]{4}$",
                "examples": [
                    "20-Sep-2026"
                ],
                "order": 3
            }
        }
    }
}